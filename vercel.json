{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/health",
      "dest": "api/index.py"
    },
    {
      "src": "/search-face",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "ENCODINGS_FILE": "backend/face_encodings.pkl",
    "METADATA_FILE": "backend/photos_metadata.pkl",
    "GDRIVE_FILE": "backend/gdrive_file_mappingf.json",
    "TOLERANCE": "0.52",
    "MAX_UPLOAD_MB": "16",
    "ALLOWED_ORIGINS": "*"
  }
}
